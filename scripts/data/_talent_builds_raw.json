        {
          "label_en": "Peacekeeping Single Target",
          "img": "https://cdn.cod.guide/wp-content/uploads/2023/01/gwanwyn-peacekeeping-single-target-talent-build-1024x722.jpg",
          "mode": "Pacificación"
